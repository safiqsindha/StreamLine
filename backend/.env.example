# Streamline Backend — environment configuration
# Copy this file to `.env` and fill in real values from your Entra ID app registration.

# ── Entra ID (Azure AD) app registration ───────────────────────────────────
# The app registration that backs Streamline's Office SSO. The Application
# (client) ID and Directory (tenant) ID come from the Azure portal Overview
# blade. The client secret is generated under "Certificates & secrets".
AAD_TENANT_ID=00000000-0000-0000-0000-000000000000
AAD_CLIENT_ID=00000000-0000-0000-0000-000000000000
AAD_CLIENT_SECRET=replace-with-real-secret

# Audience the backend expects on incoming bootstrap tokens. Must match the
# "Application ID URI" configured on the Entra app, e.g.
#   api://localhost:3000/<client-id>
# In production this becomes api://<your-host>/<client-id>.
AAD_API_AUDIENCE=api://localhost:3000/00000000-0000-0000-0000-000000000000

# ── Server ─────────────────────────────────────────────────────────────────
PORT=3001

# Origin allowed by CORS — the webpack dev server hosting the add-in.
ALLOWED_ORIGIN=https://localhost:3000

# ── HTTPS (dev) ────────────────────────────────────────────────────────────
# The backend serves HTTPS using office-addin-dev-certs (same certs the
# webpack dev server uses). Set to false to run plain HTTP for debugging.
USE_HTTPS=true

# ── Logging ────────────────────────────────────────────────────────────────
# debug | info | warn | error
LOG_LEVEL=info
